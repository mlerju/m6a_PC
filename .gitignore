# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Editor / OS
.vscode/
.idea/
*.DS_Store

# Data files (large, access-controlled — never commit raw data)
# .gitkeep files are kept to preserve directory structure
*.h5
*.hdf5
*.feather
*.parquet
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Generated results — logs and alignments are not committed; figures/tables are
results/logs/*
!results/logs/.gitkeep
results/aligned/*
!results/aligned/.gitkeep

# Unrelated in-progress sub-projects
plots_cutandrun/
m6a_cell_lines/
